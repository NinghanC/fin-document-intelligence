# LLM Configuration
# This app supports OpenAI-compatible chat clients and native AWS Bedrock chat.

MODEL_PROVIDER=openai_compatible

# Azure OpenAI example
OPENAI_API_KEY=your-azure-openai-key
OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
OPENAI_MODEL=your-azure-chat-deployment
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=auto
# Community summaries are computed during ingestion/update, not during QA.
# structured is deterministic; llm requires a real provider key.
COMMUNITY_SUMMARY_PROVIDER=structured
MODEL_CALL_TIMEOUT_SECONDS=45
MODEL_CALL_MAX_RETRIES=2
MODEL_CALL_FALLBACK_TO_DEMO=true

# Native AWS Bedrock example
# MODEL_PROVIDER=bedrock
# AWS_REGION=us-east-1
# AWS_PROFILE=
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
# BEDROCK_MAX_TOKENS=2048
# For Bedrock chat, keep embeddings local unless you add a Bedrock embedding adapter.
# EMBEDDING_PROVIDER=local

# Databricks Mosaic AI example
# OPENAI_API_KEY=your-databricks-token
# OPENAI_BASE_URL=https://your-workspace.cloud.databricks.com/serving-endpoints
# OPENAI_MODEL=databricks-meta-llama-3-1-70b-instruct

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# Local demo default only; use a managed secret in real deployments.
NEO4J_PASSWORD=local-password

# Vector Store: chroma | pgvector
VECTOR_STORE_TYPE=chroma
# Chroma mode: local uses an embedded PersistentClient; http connects to CHROMA_HOST/CHROMA_PORT.
CHROMA_MODE=local
CHROMA_HOST=localhost
CHROMA_PORT=8000
# Bounds Chroma lexical fallback scans in local/demo mode; use PGVector or an indexed lexical store for larger corpora.
CHROMA_LEXICAL_SCAN_LIMIT=1000

# PGVector (if VECTOR_STORE_TYPE=pgvector)
PGVECTOR_DSN=postgresql://postgres:postgres@localhost:5432/knowledge
# Docker Compose API container: postgresql://postgres:postgres@pgvector:5432/knowledge

# Kafka (CDC)
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
# Docker Compose API container: kafka:9092

# API
API_HOST=0.0.0.0
API_PORT=8080
# Protected by default. For a throwaway localhost-only demo, set AUTH_ENABLED=false explicitly.
AUTH_ENABLED=true
API_KEY=
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
MAX_UPLOAD_SIZE_MB=10
BATCH_UPLOAD_CONCURRENCY=4
PDF_VISION_CONCURRENCY=2

# API state backend: memory | postgres
# Use postgres when rate-limit buckets and request metrics should survive API restarts.
API_STATE_BACKEND=memory
API_STATE_DSN=postgresql://postgres:postgres@localhost:5432/knowledge
