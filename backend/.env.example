# LLM Configuration
# This app uses OpenAI-compatible chat and embedding clients.

# Azure OpenAI example
OPENAI_API_KEY=your-azure-openai-key
OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
OPENAI_MODEL=your-azure-chat-deployment
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=auto

# AWS Bedrock example, if exposed through an OpenAI-compatible gateway
# OPENAI_API_KEY=your-aws-or-gateway-key
# OPENAI_BASE_URL=https://your-bedrock-openai-compatible-endpoint/v1
# OPENAI_MODEL=anthropic.claude-3-5-sonnet-20240620-v1:0

# Databricks Mosaic AI example
# OPENAI_API_KEY=your-databricks-token
# OPENAI_BASE_URL=https://your-workspace.cloud.databricks.com/serving-endpoints
# OPENAI_MODEL=databricks-meta-llama-3-1-70b-instruct

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# Local demo default only; use a managed secret in real deployments.
NEO4J_PASSWORD=local-password

# Vector Store: chroma | pgvector
VECTOR_STORE_TYPE=chroma
# Chroma mode: local uses an embedded PersistentClient; http connects to CHROMA_HOST/CHROMA_PORT.
CHROMA_MODE=local
CHROMA_HOST=localhost
CHROMA_PORT=8000

# PGVector (if VECTOR_STORE_TYPE=pgvector)
PGVECTOR_DSN=postgresql://postgres:postgres@localhost:5432/knowledge
# Docker Compose API container: postgresql://postgres:postgres@pgvector:5432/knowledge

# Kafka (CDC)
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
# Docker Compose API container: kafka:9092

# API
API_HOST=0.0.0.0
API_PORT=8080
AUTH_ENABLED=false
API_KEY=change-me-for-protected-deployments
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
MAX_UPLOAD_SIZE_MB=10
